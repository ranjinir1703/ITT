class Solution {
    public int minimumCost(int[] nums) {
        int m=nums[0];
        int max1=100;
        int max2=100;
        for(int i=1;i<nums.length;i++){
            if(nums[i]<max1){
                max2=max1;
                max1=nums[i];
            }
            else if(nums[i]<max2){
                max2=nums[i];
            }
        }
        return m+max1+max2;
    }
}
